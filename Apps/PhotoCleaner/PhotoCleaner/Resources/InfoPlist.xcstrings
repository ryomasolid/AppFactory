{
  "sourceLanguage": "ja",
  "strings": {
    "NSPhotoLibraryUsageDescription": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "重複・類似した写真を端末内だけで検出し、削除候補として表示するために写真ライブラリにアクセスします。写真が端末外に送信されることはありません。"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Accesses your photo library to detect duplicate and similar photos on your device and suggest them for deletion. Your photos are never sent off your device."
          }
        }
      }
    },
    "NSUserTrackingUsageDescription": {
      "localizations": {
        "ja": {
          "stringUnit": {
            "state": "translated",
            "value": "あなたに関連性の高い広告を表示するために使用します。許可しなくてもアプリの機能はご利用いただけます。"
          }
        },
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Used to show ads that are more relevant to you. You can use the app fully even if you don’t allow this."
          }
        }
      }
    }
  },
  "version": "1.0"
}