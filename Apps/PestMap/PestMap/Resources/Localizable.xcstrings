        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Repeat"
          }
        }
      }
    },
    "実施した（記録して次回へ）": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Mark done (log & schedule next)"
