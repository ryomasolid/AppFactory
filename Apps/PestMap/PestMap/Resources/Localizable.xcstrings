{
  "sourceLanguage": "ja",
  "strings": {
    "はじめる": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Get Started"
          }
        }
      }
    },
    "間取りを用意": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Prepare a floor plan"
          }
        }
      }
    },
    "間取り図を撮影、または白紙から作成": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Snap a floor plan photo, or start from a blank canvas"
          }
        }
      }
    },
    "対策場所を記録": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Record treatment spots"
          }
        }
      }
    },
    "ブラックキャップなどの設置場所をマーカーで管理": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Track where you place bait traps and more"
          }
        }
      }
    },
    "次回をリマインド": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Reminds you next time"
          }
        }
      }
    },
    "交換・対策のタイミングを通知でお知らせ": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Get notified when it’s time to replace or treat"
          }
        }
      }
    },
    "間取りがありません": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "No floor plans"
          }
        }
      }
    },
    "右上の＋から間取りを追加できます": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Add a floor plan with + at the top right."
          }
        }
      }
    },
    "マーカー %lld 件 ・ %@": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "%lld markers · %@"
          }
        }
      }
    },
    "期限切れ %lld": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "%lld overdue"
          }
        }
      }
    },
    "新しい間取り": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "New Floor Plan"
          }
        }
      }
    },
    "名前（例: 1階キッチン）": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Name (e.g., 1F Kitchen)"
          }
        }
      }
    },
    "作成": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Create"
          }
        }
      }
    },
    "キャンセル": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Cancel"
          }
        }
      }
    },
    "空の間取りを作成します。写真の取り込みは次の画面で行えます。": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Creates an empty plan. You can import a photo on the next screen."
          }
        }
      }
    },
    "無題の間取り": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Untitled Plan"
          }
        }
      }
    },
    "間取りを追加": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Add floor plan"
          }
        }
      }
    },
    "リマインド一覧": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Reminders"
          }
        }
      }
    },
    "設定": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Settings"
          }
        }
      }
    },
    "タップで対策・設置場所を追加": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Tap to add a treatment/placement spot"
          }
        }
      }
    },
    "タップで編集 ・ ドラッグで移動": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Tap to edit · drag to move"
          }
        }
      }
    },
    "タップで編集、ドラッグで移動": {
      "localizations": {
        "en": {
          "stringUnit": {
            "state": "translated",
            "value": "Tap to edit, drag to move"
